generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id    String @id @default(uuid())
  name  String @unique // 'admin', 'rh', 'tuteur', 'stagiaire', 'ecole', 'universite'
  users User[]
}

model User {
  id          String      @id @default(uuid())
  email       String      @unique
  password    String
  name        String?
  roleId      String
  role        Role        @relation(fields: [roleId], references: [id])
  isValidated Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  stagiaires  Stagiaire[]
  conventions Convention[]
}

model Convention {
  id             String    @id @default(uuid())
  candidatureId  String?
  stagiaireId    String
  stagiaire      User      @relation(fields: [stagiaireId], references: [id])
  status         String    @default("generee")
  dateGeneration DateTime  @default(now())
  dateSignature  DateTime?
  dateDebut      DateTime
  dateFin        DateTime
  departement    String
  tuteurNom      String
  sujet          String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Stagiaire {
  id        String   @id @default(uuid())
  prenom    String
  nom       String
  email     String   @unique
  formation String
  niveau    String // '3eme', 'terminale', 'bts', etc.
  ecoleId   String
  ecole     User     @relation(fields: [ecoleId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CandidatureExterne {
  id                   String    @id @default(uuid())
  nom                  String
  prenom               String
  email                String
  telephone            String
  adresse              String?
  ville                String?
  codePostal           String?
  formation            String
  niveau               String
  dateDebut            String
  duree                String
  message              String?
  cvUrl                String
  lettreMotivationUrl  String
  status               String    @default("nouvelle")
  dateSoumission       DateTime  @default(now())
  departementAffecte   String?
  commentairesRH       String?
  dateDecision         DateTime?
  compteCreeLe         DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([status])
  @@index([email])
}

