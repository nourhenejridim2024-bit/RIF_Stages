generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id    String @id @default(uuid())
  name  String @unique
  users User[]
}

model User {
  id                                     String      @id @default(uuid())
  email                                  String      @unique
  password                               String
  name                                   String?
  roleId                                 String
  isValidated                            Boolean     @default(false)
  createdAt                              DateTime    @default(now())
  updatedAt                              DateTime    @updatedAt
  stagiaires                             Stagiaire[]
  Stagiaire_Stagiaire_universiteIdToUser Stagiaire[] @relation("Stagiaire_universiteIdToUser")
  role                                   Role        @relation(fields: [roleId], references: [id])
}

model Convention {
  id             String    @id @default(uuid())
  candidatureId  String?
  stagiaireId    String
  status         String    @default("generee")
  dateGeneration DateTime  @default(now())
  dateSignature  DateTime?
  dateDebut      DateTime
  dateFin        DateTime
  departement    String
  tuteurNom      String
  sujet          String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Stagiaire {
  id                                String   @id @default(uuid())
  prenom                            String
  nom                               String
  email                             String   @unique
  formation                         String
  niveau                            String
  ecoleId                           String
  createdAt                         DateTime @default(now())
  updatedAt                         DateTime @updatedAt
  universiteId                      String?
  ecole                             User     @relation(fields: [ecoleId], references: [id])
  User_Stagiaire_universiteIdToUser User?    @relation("Stagiaire_universiteIdToUser", fields: [universiteId], references: [id])
}

model CandidatureExterne {
  id                  String    @id @default(uuid())
  nom                 String
  prenom              String
  email               String
  telephone           String
  adresse             String?
  ville               String?
  codePostal          String?
  formation           String
  niveau              String
  dateDebut           String
  duree               String
  message             String?
  cvUrl               String
  lettreMotivationUrl String
  status              String    @default("nouvelle")
  dateSoumission      DateTime  @default(now())
  departementAffecte  String?
  commentairesRH      String?
  dateDecision        DateTime?
  compteCreeLe        DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([status])
  @@index([email])
}
